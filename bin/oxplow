#!/usr/bin/env bash
set -euo pipefail

# Launcher for the Tauri-based oxplow desktop app.
#
# Behavior:
#   - In dev (no built binary present): runs `cargo tauri dev` from
#     apps/desktop/. cargo handles building the Rust + spawning Vite.
#   - In production: execs the bundled Tauri binary if it's present at
#     target/release/oxplow, falling back to the dev path otherwise.
#
# `--project <dir>` (positional or first arg) selects the project the
# daemon should serve; the Rust side reads $PWD when not overridden.

DIR="$(cd "$(dirname "$0")/.." && pwd)"

if [ -x "$DIR/target/release/oxplow" ]; then
  exec "$DIR/target/release/oxplow" "$@"
fi

if [ -x "$DIR/target/debug/oxplow" ]; then
  exec "$DIR/target/debug/oxplow" "$@"
fi

# No built binary: developer mode.
echo "[oxplow] no built binary at target/{debug,release}/oxplow — running 'cargo tauri dev'" >&2
cd "$DIR/apps/desktop"
exec cargo tauri dev "$@"
