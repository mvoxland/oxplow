{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "main-window",
  "description": "Capabilities granted to the primary oxplow webview. shell:default is replaced with a narrowly-scoped allowlist + open-url permission so the renderer can't spawn arbitrary processes.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "clipboard-manager:default",
    "updater:default",
    "shell:allow-open",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        { "name": "tmux", "cmd": "tmux", "args": true },
        { "name": "git", "cmd": "git", "args": true },
        {
          "name": "typescript-language-server",
          "cmd": "typescript-language-server",
          "args": true
        }
      ]
    }
  ]
}
