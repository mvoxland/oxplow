{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    // Strict knobs still relaxed. Flipping any of these on surfaces
    // ~50–250 errors across the legacy UI (mostly possibly-undefined
    // accesses on optional fields like `session.openOrder`,
    // `window.oxplowApi`, and various map results). Each is fixable
    // at its call site but it's a focused per-file pass — defer
    // until the legacy adapter shrinks further. The migration
    // banner stays in the comment block above so we don't forget.
    "noUncheckedIndexedAccess": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "allowImportingTsExtensions": false,
    "noEmit": true,
    "isolatedModules": true,
    "useDefineForClassFields": true
  },
  "include": ["src/**/*"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
