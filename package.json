{
  "name": "oxplow-workspace",
  "version": "0.4.1",
  "private": true,
  "type": "module",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run --cwd apps/desktop dev",
    "build": "bun run --cwd apps/desktop build",
    "typecheck": "bun run --cwd apps/desktop typecheck",
    "test": "bun run --cwd apps/desktop test && cargo test --workspace",
    "test:rust": "cargo test --workspace",
    "test:ts": "bun run --cwd apps/desktop test",
    "tauri:dev": "OXPLOW_PROJECT_DIR=\"$PWD\" bun run --cwd apps/desktop tauri dev",
    "tauri:build": "bun run --cwd apps/desktop tauri build",
    "e2e": "bunx playwright test"
  },
  "devDependencies": {
    "playwright": "^1.59.1",
    "typescript": "^5.5.0"
  }
}
